# ─────────────────────────────────────────
# App
# ─────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3003

# ─────────────────────────────────────────
# Database — Neon (free tier at neon.tech)
# ─────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# ─────────────────────────────────────────
# NextAuth / Auth.js v5
# Generate secret: openssl rand -base64 32
# ─────────────────────────────────────────
AUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3003"

# GitHub OAuth (github.com/settings/developers → New OAuth App)
AUTH_GITHUB_ID="your-github-client-id"
AUTH_GITHUB_SECRET="your-github-client-secret"

# Google OAuth (console.cloud.google.com → APIs → Credentials)
AUTH_GOOGLE_ID="your-google-client-id"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# ─────────────────────────────────────────
# Private GitHub repo (pro components)
# Create fine-grained PAT with read-only
# access ONLY to pro.shadcnagents.com
# ─────────────────────────────────────────
GITHUB_PRIVATE_TOKEN="ghp_your_token_here"
PRO_GITHUB_REPO="shadcnagents/pro.shadcnagents.com"

# ─────────────────────────────────────────
# Polar.sh Payments (polar.sh)
# Dashboard → Settings → Developers
# ─────────────────────────────────────────
POLAR_WEBHOOK_SECRET="your-polar-webhook-secret"
POLAR_ACCESS_TOKEN="your-polar-access-token"
POLAR_ORGANIZATION_ID="your-polar-org-id"

# Product IDs (Polar Dashboard → Products)
NEXT_PUBLIC_POLAR_PRO_PRODUCT_ID="your-pro-product-id"
NEXT_PUBLIC_POLAR_TEAM_PRODUCT_ID="your-team-product-id"

# Checkout URLs (Polar Dashboard → Products → Checkout Link)
NEXT_PUBLIC_POLAR_PRO_URL="https://polar.sh/checkout/your-pro-link"
NEXT_PUBLIC_POLAR_TEAM_URL="https://polar.sh/checkout/your-team-link"

# ─────────────────────────────────────────
# PostHog Analytics (posthog.com — free)
# ─────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY="phc_your_key_here"
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"
